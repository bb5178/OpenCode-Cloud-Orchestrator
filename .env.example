# ============================================================
# OCO Environment Variables
# ============================================================
# Copy this to .env and fill in your values.
# Never commit .env to git.

# --- Cloudflare API (for wrangler deploy) ---
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token

# --- OCO Runner ---
OCO_URL=https://oco.yourdomain.com
OCO_API_TOKEN=your_oco_api_token
OCO_ACCESS_CLIENT_ID=your_access_client_id.access
OCO_ACCESS_CLIENT_SECRET=your_access_client_secret
